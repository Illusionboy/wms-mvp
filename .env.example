POSTGRES_DB=wms
POSTGRES_USER=wms_user
POSTGRES_PASSWORD=wms_password
POSTGRES_PORT=5432
API_PORT=8000

DATABASE_URL=postgresql+asyncpg://wms_user:wms_password@postgres:5432/wms
APP_NAME=WMS Inventory API
APP_ENV=local
DEBUG=false

# Web UI 管理员账号（首次启动自动创建，已存在则不覆盖）
# 之后在 Web UI 设置页改密码
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# JWT 签名密钥，必须设置（否则默认值不安全）
# 生成: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# API Key for mutation endpoints (stock-in/out, imports, chat-reports, etc.)
# Set to a long random string. All X-API-Key requests must match this value.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change-me
TELEGRAM_WEBHOOK_PATH=/api/v1/telegram/webhook
# local_polling 不需要公网域名；webhook 需要公网 HTTPS URL。
TELEGRAM_BOT_MODE=local_polling

# Telegram 权限白名单，填 Telegram user_id，多个用英文逗号分隔。
# 留空 TELEGRAM_QUERY_USER_IDS 时，任何能找到 bot 的用户都可以查询。
# operator 可以 stock_in / stock_out / stock_adjust / transfer。
# admin 可以 add_product / add_customer，并自动拥有 operator/query 权限。
TELEGRAM_QUERY_USER_IDS=1039601553
TELEGRAM_OPERATOR_USER_IDS=1039601553
TELEGRAM_ADMIN_USER_IDS=1039601553

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# 秦丝生意通爬虫（可选，不配置则爬虫功能禁用）
QINSI_USERNAME=
QINSI_PASSWORD=
# 如需自定义登录地址（默认无需修改）
# QINSI_BASE_URL=https://web.syt.qinsilk.com/gis/admin/
