# ── 最小可运行配置（云部署无 AI/集成 Key 也能启动） ─────────────────────────
# 必填：POSTGRES_* + JWT_SECRET_KEY + ADMIN_USERNAME/ADMIN_PASSWORD（否则无法登录）
# 可留空：API_KEY、TELEGRAM_*、GEMINI_*、QINSI_*（对应功能按需禁用，不影响启动）
# 默认 `docker compose up -d` 只起 postgres + api；Telegram bot 已移到 profile，不会启动。
# ──────────────────────────────────────────────────────────────────────────
POSTGRES_DB=wms
POSTGRES_USER=wms_user
POSTGRES_PASSWORD=wms_password
POSTGRES_PORT=5432
API_PORT=8000
# 云部署（公网 VPS + Nginx Proxy Manager）设为 127.0.0.1：Postgres/API 只在本机可达、
# 公网仅走 NPM 的 80/443。本地开发留空即可（默认 0.0.0.0，方便宿主机直接连）。
# BIND_HOST=127.0.0.1

APP_ENV=local
DEBUG=false

# Web UI 管理员账号（首次启动自动创建，已存在则不覆盖）
# 之后在 Web UI 设置页改密码
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# JWT 签名密钥，必须设置（否则默认值不安全）
# 生成: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# API Key（可选）：仅用于 X-API-Key 的脚本/工具调用。网页端用 JWT 登录，不依赖它。
# 留空 → X-API-Key 通道禁用（返回 503），但网页端所有功能正常。
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=

# Telegram bot（可选）：云部署暂不启用。默认 compose 不启动 bot 服务（已移入 telegram profile）。
# 需要时：配置 token 后 `docker compose --profile telegram up -d`
TELEGRAM_BOT_TOKEN=
# Telegram 白名单（user_id，多个用英文逗号分隔）；留空则任何能找到 bot 的用户都可查询
TELEGRAM_QUERY_USER_IDS=

# Gemini（可选）：留空 → 微信报库/贸易出库拍照/盘点列LLM兜底 等 AI 功能禁用（调用时报清晰错误），不影响启动
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# 秦丝生意通爬虫（可选，不配置则爬虫功能禁用）
QINSI_USERNAME=
QINSI_PASSWORD=
# 如需自定义登录地址（默认无需修改）
# QINSI_BASE_URL=https://web.syt.qinsilk.com/gis/admin/

# 秦丝仓库 → WMS仓库 映射表（JSON格式）
# QINSI_WAREHOUSE_MAP={"北津守仓库":"普通仓库","乐天仓库":"乐天仓库"}
